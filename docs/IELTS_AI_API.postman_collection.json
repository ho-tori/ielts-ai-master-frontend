{
  "info": {
    "name": "IELTS AI Backend API",
    "description": "IELTS AI 后端 API 文档",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "认证模块",
      "item": [
        {
          "name": "用户注册",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"123456\",\n  \"nickname\": \"测试用户\",\n  \"email\": \"test@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "用户登录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "获取用户信息",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/profile",
              "host": ["{{base_url}}"],
              "path": ["auth", "profile"]
            }
          }
        },
        {
          "name": "更新用户资料",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickname\": \"新昵称\",\n  \"email\": \"newemail@example.com\",\n  \"avatar\": \"https://example.com/avatar.jpg\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/profile",
              "host": ["{{base_url}}"],
              "path": ["auth", "profile"]
            }
          }
        },
        {
          "name": "修改密码",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"newpassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/security",
              "host": ["{{base_url}}"],
              "path": ["auth", "security"]
            }
          }
        }
      ]
    },
    {
      "name": "文章模块",
      "item": [
        {
          "name": "获取文章列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/articles?page=0&size=10&examType=IELTS&difficulty=medium",
              "host": ["{{base_url}}"],
              "path": ["articles"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "examType",
                  "value": "IELTS"
                },
                {
                  "key": "difficulty",
                  "value": "medium"
                }
              ]
            }
          }
        },
        {
          "name": "获取文章详情",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/articles/1",
              "host": ["{{base_url}}"],
              "path": ["articles", "1"]
            }
          }
        },
        {
          "name": "提交答案",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"questionId\": 1,\n  \"userAnswer\": \"A\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/articles/1/submit",
              "host": ["{{base_url}}"],
              "path": ["articles", "1", "submit"]
            }
          }
        }
      ]
    },
    {
      "name": "AI 分析模块",
      "item": [
        {
          "name": "AI 文本分析",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"The quick brown fox jumps over the lazy dog.\",\n  \"articleTitle\": \"动物相关\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/ai/analyze",
              "host": ["{{base_url}}"],
              "path": ["ai", "analyze"]
            }
          }
        }
      ]
    },
    {
      "name": "统计模块",
      "item": [
        {
          "name": "获取用户统计",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/stats",
              "host": ["{{base_url}}"],
              "path": ["stats"]
            }
          }
        }
      ]
    },
    {
      "name": "管理员模块",
      "item": [
        {
          "name": "上传文章",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"人工智能与未来社会\",\n  \"examType\": \"IELTS\",\n  \"difficulty\": \"hard\",\n  \"topicCodes\": [\"technology\", \"humanity\"],\n  \"paragraphs\": [\n    {\n      \"paragraphNumber\": 1,\n      \"content\": \"Artificial intelligence (AI) is the simulation of human intelligence processes by computer systems. These processes include learning, reasoning, and self-correction.\",\n      \"translation\": \"人工智能(AI)是计算机系统对人类智能过程的模拟。这些过程包括学习、推理和自我纠正。\",\n      \"sentenceList\": [\n        \"Artificial intelligence (AI) is the simulation of human intelligence processes by computer systems.\",\n        \"These processes include learning, reasoning, and self-correction.\"\n      ],\n      \"sentenceTranslationList\": [\n        \"人工智能(AI)是计算机系统对人类智能过程的模拟。\",\n        \"这些过程包括学习、推理和自我纠正。\"\n      ]\n    }\n  ],\n  \"questions\": [\n    {\n      \"questionNumber\": 1,\n      \"questionTypeCode\": \"single_choice\",\n      \"stem\": \"According to the passage, what is AI?\",\n      \"options\": [\n        {\n          \"label\": \"A\",\n          \"content\": \"The simulation of human intelligence processes\"\n        },\n        {\n          \"label\": \"B\",\n          \"content\": \"A type of computer\"\n        },\n        {\n          \"label\": \"C\",\n          \"content\": \"Only for learning\"\n        },\n        {\n          \"label\": \"D\",\n          \"content\": \"A programming language\"\n        }\n      ],\n      \"correctAnswer\": \"A\",\n      \"analysis\": \"第一句话明确指出AI是计算机系统对人类智能过程的模拟。\",\n      \"answerParagraphNumber\": 1,\n      \"answerSentenceIndex\": 0\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/uploadArticle",
              "host": ["{{base_url}}"],
              "path": ["admin", "uploadArticle"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}

